# Justfile for testing lexer.py and parser.py

# Default target
default: test

# Run lexer
lexer:
    python3 lexer.py

# Run parser
parser:
    python3 parser.py

# Run both (basic pipeline)
test:
    python3 lexer.py
    python3 parser.py

# Run lexer on a specific file
lex file:
    python3 lexer.py {{file}}

# Run parser on a specific file
parse file:
    python3 parser.py {{file}}

# Run full pipeline on a file
run file:
    python3 lexer.py {{file}}
    python3 parser.py {{file}}

# Watch mode (requires entr: brew install entr)
watch:
    ls *.py | entr -c just test

# Clean pycache
clean:
    find . -type d -name "__pycache__" -exec rm -r {} +

# Optional: verbose debug run
debug file:
    python3 lexer.py {{file}}
    echo "-----------------"
    python3 parser.py {{file}}